# =============================================================================
# RepoSwarm Environment Configuration
# =============================================================================
# Copy this file to .env.local and uncomment/edit the values you need.
#
# There are 6 modes of operation. Pick the one that fits your use case
# and uncomment the relevant variables:
#
#   MODE 1: Local repos, Claude only (no Architecture Hub)
#           Analyse repos on disk with Claude, save results locally.
#           Simplest AI setup -- no GitHub token needed.
#
#   MODE 2: Remote repos, Claude + Architecture Hub
#           Clone repos from GitHub, analyse with Claude, push results
#           to an Architecture Hub repo on GitHub.
#
#   MODE 3: Remote repos, Claude only (no Architecture Hub)
#           Clone repos from GitHub, analyse with Claude, save results
#           locally. Needs GITHUB_TOKEN for cloning only.
#
#   MODE 4: Diagrams only (re-render from cached results)
#           Skip investigation, just regenerate cross-repo diagrams
#           and/or PNGs from previously cached analysis.
#
#   MODE 5: Local repos, Static Analysis (no AI)
#           Analyse repos on disk using programmatic static analysis.
#           No API key or credits needed.
#
#   MODE 6: Local repos, Static Analysis + Diagrams (no AI)
#           Static analysis + programmatic Mermaid diagram generation.
#           Generates 8 diagram types with narrative text. No API key needed.
#
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED FOR MODES 1-4 -- Claude API
# (Not needed for Modes 5-6 when ENABLE_AI=false)
# -----------------------------------------------------------------------------
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# AI toggle -- set to false for Modes 5-6 (static analysis, no Claude API)
# ENABLE_AI=true

# Claude model to use (optional -- defaults to claude-sonnet-4-5-20250929)
# Options: claude-sonnet-4-5-20250929, claude-opus-4-5-20250514, claude-3-haiku-20241022
# CLAUDE_MODEL=claude-sonnet-4-5-20250929


# -----------------------------------------------------------------------------
# REQUIRED FOR ALL MODES -- Temporal (workflow engine)
# -----------------------------------------------------------------------------
# Defaults below are correct for local dev (mise dev-server)
TEMPORAL_SERVER_URL=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=investigate-task-queue
TEMPORAL_IDENTITY=local-worker


# =============================================================================
# MODE 1: Local repos, Claude only (no Architecture Hub)
# =============================================================================
# Analyses repos on your disk. No GitHub access needed.
# Configure repos in prompts/repos.json with file:// URIs for each repo.
# Run with: mise investigate-local
# -----------------------------------------------------------------------------
# LOCAL_TESTING=true
# LOCAL_MODE=true
# SKIP_DYNAMODB_CHECK=true
# PROMPT_CONTEXT_STORAGE=file
# LOCAL_OUTPUT_DIR=outputs


# =============================================================================
# MODE 2: Remote repos, Claude + Architecture Hub
# =============================================================================
# Clones repos from GitHub, analyses with Claude, pushes markdown results
# to an Architecture Hub repository on GitHub.
# Configure repos in prompts/repos.json with https:// URIs for each repo.
# Run with: mise investigate-all
# -----------------------------------------------------------------------------

# GitHub token -- needed to clone repos and push to Architecture Hub
# Create at: https://github.com/settings/tokens (needs repo scope)
# GITHUB_TOKEN=ghp_your-token-here

# Architecture Hub -- the GitHub repo where analysis results are pushed
# ARCH_HUB_REPO_NAME=architecture-hub
# ARCH_HUB_BASE_URL=https://github.com/your-org
# ARCH_HUB_FILES_DIR=           # empty = root of the repo

# Organisation/owner of the repos being analysed
# DEFAULT_ORG_NAME=your-org
# DEFAULT_REPO_URL=https://github.com/your-org/default-repo

# Git identity used for commits to the Architecture Hub
# GIT_USER_NAME=Architecture Bot
# GIT_USER_EMAIL=architecture-bot@your-org.com

# Cache in DynamoDB (default for remote mode)
# LOCAL_TESTING=false
# SKIP_DYNAMODB_CHECK=false
# PROMPT_CONTEXT_STORAGE=dynamodb


# =============================================================================
# MODE 3: Remote repos, Claude only (no Architecture Hub)
# =============================================================================
# Clones repos from GitHub, analyses with Claude, saves results locally.
# Same as Mode 2 but results stay on disk instead of pushing to GitHub.
# Run with: mise investigate-all
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_your-token-here
# LOCAL_TESTING=true
# SKIP_DYNAMODB_CHECK=true
# PROMPT_CONTEXT_STORAGE=file
# LOCAL_OUTPUT_DIR=outputs
# LOCAL_MODE=false               # false = clone from GitHub, not read from disk

# Architecture Hub placeholders (still required but won't be pushed to)
# ARCH_HUB_REPO_NAME=local-only
# ARCH_HUB_BASE_URL=https://github.com/local-only
# ARCH_HUB_FILES_DIR=
# DEFAULT_ORG_NAME=local-only
# DEFAULT_REPO_URL=https://github.com/sindresorhus/is
# GIT_USER_NAME=Test Bot
# GIT_USER_EMAIL=test@example.com


# =============================================================================
# MODE 5: Local repos, Static Analysis (no AI)
# =============================================================================
# Analyses repos on your disk using programmatic static analysis scanners.
# No ANTHROPIC_API_KEY needed. Outputs the same .arch.md format as Claude.
# Configure repos in prompts/repos.json with file:// URIs for each repo.
# Run with: mise investigate-local
# -----------------------------------------------------------------------------
# ENABLE_AI=false
# LOCAL_TESTING=true
# LOCAL_MODE=true
# SKIP_DYNAMODB_CHECK=true
# PROMPT_CONTEXT_STORAGE=file
# LOCAL_OUTPUT_DIR=outputs


# =============================================================================
# MODE 6: Local repos, Static Analysis + Diagrams (no AI)
# =============================================================================
# Same as Mode 5 but also generates Mermaid diagrams programmatically.
# Produces 8 diagram types (lifecycle, overview, tech stack, infrastructure,
# data flow, module structure, language pie chart, sequence diagrams) plus
# narrative text (key connections, data flow summary, governance concerns).
# No ANTHROPIC_API_KEY needed.
# Run with: mise investigate-local
# -----------------------------------------------------------------------------
# ENABLE_AI=false
# CREATE_DIAGRAMS=true
# RENDER_MERMAID_PNGS=true
# LOCAL_TESTING=true
# LOCAL_MODE=true
# SKIP_DYNAMODB_CHECK=true
# PROMPT_CONTEXT_STORAGE=file
# LOCAL_OUTPUT_DIR=outputs


# =============================================================================
# CROSS-REPO DIAGRAMS (optional -- works with any mode above)
# =============================================================================
# After all repos are analysed, Claude generates cross-repo Mermaid diagrams
# showing architecture, sequences, and data flows across repos.
# -----------------------------------------------------------------------------

# Generate Mermaid markdown diagrams (saved to outputs/diagrams/)
# CREATE_DIAGRAMS=true

# Render Mermaid diagrams to PNG images (requires Docker)
# Build the Docker image first: mise mermaid-build
# RENDER_MERMAID_PNGS=true

# Docker image used for PNG rendering (default: repo-swarm-mermaid:local)
# MERMAID_DOCKER_IMAGE=repo-swarm-mermaid:local

# Timeout in seconds for rendering each diagram (default: 120)
# MERMAID_RENDER_TIMEOUT=120


# =============================================================================
# OPTIONAL -- DynamoDB (only for Mode 2 with cloud caching)
# =============================================================================
# For local DynamoDB testing or AWS-hosted caching
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=local
# AWS_SECRET_ACCESS_KEY=local
# AWS_REGION=us-east-1
# DYNAMODB_ENDPOINT_URL=http://localhost:8000


# =============================================================================
# OPTIONAL -- Debug settings
# =============================================================================
# LOG_LEVEL=DEBUG
# PYTHONUNBUFFERED=1
