{
  "default": "https://github.com/ascpixi/is-odd",
  "_comment": "Available types: generic, backend, frontend, mobile, infra-as-code, libraries",
  "repositories": {
    "repo-swarm": {
      "uri": "https://github.com/royosherove/repo-swarm",
      "description": "AI-powered multi-repo architecture discovery platform",
      "type": "backend"
    },
    "_comment_react": "=== React Ecosystem (core + state + routing) ===",
    "react": {
      "uri": "https://github.com/facebook/react",
      "description": "React core library - the foundation of the React ecosystem",
      "type": "frontend"
    },
    "react-router": {
      "uri": "https://github.com/remix-run/react-router",
      "description": "Declarative routing for React (depends on React)",
      "type": "frontend"
    },
    "redux-toolkit": {
      "uri": "https://github.com/reduxjs/redux-toolkit",
      "description": "Official Redux toolset (commonly used with React)",
      "type": "libraries"
    },
    "zustand": {
      "uri": "https://github.com/pmndrs/zustand",
      "description": "Lightweight state management for React (alternative to Redux)",
      "type": "libraries"
    },
    "_comment_vue": "=== Vue Ecosystem (core + state) ===",
    "vue": {
      "uri": "https://github.com/vuejs/core",
      "description": "Vue.js 3 core - progressive JavaScript framework",
      "type": "frontend"
    },
    "pinia": {
      "uri": "https://github.com/vuejs/pinia",
      "description": "Vue state management (depends on Vue, official replacement for Vuex)",
      "type": "libraries"
    },
    "_comment_nextjs": "=== Next.js / Vercel Ecosystem ===",
    "nextjs": {
      "uri": "https://github.com/vercel/next.js",
      "description": "React full-stack framework (depends on React)",
      "type": "frontend"
    },
    "swr": {
      "uri": "https://github.com/vercel/swr",
      "description": "React data fetching library (commonly used with Next.js)",
      "type": "libraries"
    },
    "ai": {
      "uri": "https://github.com/vercel/ai",
      "description": "Vercel AI SDK for building AI-powered apps (integrates with Next.js)",
      "type": "libraries"
    },
    "_comment_build": "=== Build Tools (interdependent bundlers) ===",
    "vite": {
      "uri": "https://github.com/vitejs/vite",
      "description": "Next-gen frontend build tool (uses esbuild and Rollup internally)",
      "type": "libraries"
    },
    "rollup": {
      "uri": "https://github.com/rollup/rollup",
      "description": "ES module bundler (Vite uses this for production builds)",
      "type": "libraries"
    },
    "_comment_backend": "=== Node.js Backend Frameworks ===",
    "express": {
      "uri": "https://github.com/expressjs/express",
      "description": "Classic Node.js web framework - industry standard",
      "type": "backend"
    },
    "fastify": {
      "uri": "https://github.com/fastify/fastify",
      "description": "Modern high-performance Node.js web framework",
      "type": "backend"
    },
    "trpc": {
      "uri": "https://github.com/trpc/trpc",
      "description": "End-to-end typesafe APIs (commonly used with Next.js + Prisma)",
      "type": "backend"
    },
    "_comment_orm": "=== Database / ORM ===",
    "prisma": {
      "uri": "https://github.com/prisma/prisma",
      "description": "Type-safe database toolkit and ORM for Node.js",
      "type": "backend"
    },
    "drizzle-orm": {
      "uri": "https://github.com/drizzle-team/drizzle-orm",
      "description": "TypeScript ORM (alternative to Prisma, lighter weight)",
      "type": "backend"
    },
    "_comment_testing": "=== Testing Frameworks ===",
    "jest": {
      "uri": "https://github.com/jestjs/jest",
      "description": "JavaScript testing framework by Meta",
      "type": "libraries"
    },
    "vitest": {
      "uri": "https://github.com/vitest-dev/vitest",
      "description": "Vite-native testing framework (mirrors Jest API, integrates with Vite)",
      "type": "libraries"
    },
    "_comment_mobile": "=== Mobile ===",
    "expo": {
      "uri": "https://github.com/expo/expo",
      "description": "React Native framework and platform (depends on React)",
      "type": "mobile"
    },
    "_comment_ai": "=== AI/ML ===",
    "langchainjs": {
      "uri": "https://github.com/langchain-ai/langchainjs",
      "description": "LangChain for JavaScript - LLM application framework",
      "type": "libraries"
    }
  }
}